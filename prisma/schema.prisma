generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  businessName     String?
  fullName         String
  email            String    @unique
  phone            String?
  password         String
  role             String    @default("CLIENT")
  segment          String    @default("General")
  status           String    @default("ACTIVE")
  resetToken       String?
  resetTokenExpiry DateTime?

  // Extended profile
  businessIndustry  String?
  businessType      String?
  website           String? @db.Text
  address           String? @db.Text
  city              String?
  state             String?
  zipCode           String?
  country           String?
  preferredComm     String?
  preferredApptTime String?
  billingContact    String?
  billingEmail      String?
  taxId             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
}

model ServiceRequest {
  id           Int      @id @default(autoincrement())
  serviceGroup String
  projectTitle String
  businessName String
  contactName  String
  email        String
  phone        String?
  budgetRange  String?
  desiredDate  String?
  description  String?  @db.Text
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id              Int               @id @default(autoincrement())
  title           String
  serviceGroup    String
  clientName      String
  clientEmail     String
  clientUserId    Int?
  description     String?           @db.Text
  status          String            @default("IN_PROGRESS")
  progress        Int               @default(0)
  sourceRequestId Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  activities      ProjectActivity[]
}

model Invoice {
  id        Int  @id @default(autoincrement())
  projectId Int?

  invoiceNumber String @unique

  clientName  String
  clientEmail String

  serviceDescription String @db.Text

  serviceAmount Float @default(0)
  domainAmount  Float @default(0)
  hostingAmount Float @default(0)

  shippingAmount     Float @default(0)
  installationAmount Float @default(0)

  taxAmount      Float @default(0)
  discountAmount Float @default(0)

  totalAmount Float @default(0)

  status String @default("DRAFT")

  dueDate DateTime?
  notes   String?   @db.Text

  // Stripe payment tracking
  stripePaymentIntentId String?
  paidAt                DateTime?
  clientId              Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectFile {
  id           Int      @id @default(autoincrement())
  projectId    Int
  originalName String
  filename     String
  path         String   @db.Text
  createdAt    DateTime @default(now())
}

model ProjectMessage {
  id             Int      @id @default(autoincrement())
  projectId      Int
  sender         String
  senderRole     String   @default("CLIENT")
  message        String   @db.Text
  isReadByClient Boolean  @default(false)
  isReadByStaff  Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  segment     String
  subject     String
  emailTitle  String
  emailBody   String   @db.Text
  buttonText  String?
  buttonLink  String?  @db.Text
  bannerImage String?  @db.Text
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CampaignLog {
  id           Int      @id @default(autoincrement())
  campaignName String
  segment      String
  recipients   Int
  successCount Int
  failedCount  Int
  status       String   @default("SENT")
  createdAt    DateTime @default(now())
}

model ServiceGroup {
  id           Int     @id @default(autoincrement())
  name         String
  description  String? @db.Text
  imageUrl     String? @db.Text
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  featured     Boolean @default(false)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id Int @id @default(autoincrement())

  serviceGroupId Int

  title         String
  description   String? @db.Text
  startingPrice Float?

  featured     Boolean @default(false)
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  imageUrl String? @db.Text

  serviceGroup ServiceGroup @relation(fields: [serviceGroupId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectActivity {
  id        Int @id @default(autoincrement())
  projectId Int

  action  String
  details String? @db.Text

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id         Int      @id @default(autoincrement())
  name       String
  category   String   @default("General")
  subject    String
  emailTitle String
  emailBody  String   @db.Text
  buttonText String?
  buttonLink String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id          Int     @id @default(autoincrement())
  title       String
  serviceType String
  date        String
  timeSlot    String
  notes       String? @db.Text
  status      String  @default("PENDING")

  // Zoom meeting fields (optional — set when a Zoom meeting is linked)
  zoomMeetingId String?
  zoomJoinUrl   String? @db.Text
  zoomStartUrl  String? @db.Text

  createdByUserId Int
  createdByName   String
  createdByEmail  String
  createdByRole   String

  targetUserId Int?
  targetName   String?
  targetEmail  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ZoomWebhookLog {
  id        Int      @id @default(autoincrement())
  event     String
  meetingId String?
  payload   String   @db.Text
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteBanner {
  id        Int      @id @default(autoincrement())
  title     String   @default("Everything Your Business Needs to Grow")
  subtitle  String?  @db.Text
  imageUrl  String?  @db.Text
  cta1Text  String?  @default("Request Service")
  cta1Page  String?  @default("Request Service")
  cta2Text  String?  @default("Explore Services")
  cta2Page  String?  @default("Services")
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
